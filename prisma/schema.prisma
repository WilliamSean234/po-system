// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String  @id @default(uuid())
  tenantId  String
  name      String
  email     String  @unique
  password  String
  role      String  // "admin", "purchasing", "warehouse", "finance"
  isActive  Boolean @default(true)

  tenant   Tenant  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Vendor {
  id          String  @id @default(uuid())
  tenantId    String
  code        String
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  paymentTerms String?
  isActive    Boolean @default(true)

  tenant      Tenant  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Item {
  id          String  @id @default(uuid())
  tenantId    String
  code        String
  name        String
  description String?
  uom         String
  category    String?
  isActive    Boolean @default(true)

  tenant      Tenant  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model Tenant{
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  plan      String    @default("free")
  createdAt DateTime  @default(now())   
  users     User[]
  Vendor    Vendor[]
  Item      Item[]
}